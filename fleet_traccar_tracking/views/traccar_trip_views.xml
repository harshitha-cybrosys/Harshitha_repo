<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_traccar_trip_list" model="ir.ui.view">
        <field name="name">fleet.traccar.trip.list</field>
        <field name="model">fleet.traccar.trip</field>
        <field name="arch" type="xml">
            <list string="Trips" decoration-success="distance > 0">
                <field name="vehicle_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="duration" widget="float_time" string="Duration (h:m)"/>
                <field name="distance" string="Distance (km)"/>
                <field name="avg_speed"/>
                <field name="max_speed"/>
                <field name="start_address"/>
                <field name="end_address"/>
                <field name="position_count"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_traccar_trip_form" model="ir.ui.view">
        <field name="name">fleet.traccar.trip.form</field>
        <field name="model">fleet.traccar.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Trip Details">
                            <field name="vehicle_id"/>
                            <field name="device_id"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="duration" string="Duration (min)"/>
                            <field name="distance"/>
                        </group>
                        <group string="Speed">
                            <field name="avg_speed"/>
                            <field name="max_speed"/>
                        </group>
                    </group>
                    <group>
                        <group string="Start Location">
                            <field name="start_address"/>
                            <field name="start_lat"/>
                            <field name="start_lng"/>
                        </group>
                        <group string="End Location">
                            <field name="end_address"/>
                            <field name="end_lat"/>
                            <field name="end_lng"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="GPS Points">
                            <field name="position_ids" readonly="1">
                                <list>
                                    <field name="fix_time"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="speed"/>
                                    <field name="altitude"/>
                                    <field name="battery_level"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_traccar_trips" model="ir.actions.act_window">
        <field name="name">Trip History</field>
        <field name="res_model">fleet.traccar.trip</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>