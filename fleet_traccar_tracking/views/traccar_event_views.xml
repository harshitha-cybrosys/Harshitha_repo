<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_traccar_event_list" model="ir.ui.view">
        <field name="name">fleet.traccar.event.list</field>
        <field name="model">fleet.traccar.event</field>
        <field name="arch" type="xml">
            <list string="Traccar Events"
                  decoration-danger="event_type in ('deviceOverspeed','alarm')"
                  decoration-warning="event_type in ('geofenceExit','geofenceEnter')"
                  decoration-info="event_type in ('deviceOnline','deviceOffline')">
                <field name="event_time"/>
                <field name="vehicle_id"/>
                <field name="device_id"/>
                <field name="event_type"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_traccar_event_form" model="ir.ui.view">
        <field name="name">fleet.traccar.event.form</field>
        <field name="model">fleet.traccar.event</field>
        <field name="arch" type="xml">
            <form string="Traccar Event">
                <sheet>
                    <group>
                        <group string="Event Info">
                            <field name="event_type"/>
                            <field name="event_time"/>
                            <field name="notes"/>
                        </group>
                        <group string="Device">
                            <field name="vehicle_id"/>
                            <field name="device_id"/>
                            <field name="position_id"/>
                            <field name="traccar_event_id"/>
                            <field name="geofence_id"/>
                        </group>
                    </group>
                    <group string="Raw Data">
                        <field name="attributes" widget="json"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fleet_traccar_events" model="ir.actions.act_window">
        <field name="name">Traccar Events Log</field>
        <field name="res_model">fleet.traccar.event</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>