<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Invoice / Vendor Bill — only show when move_type is set -->
    <t t-name="ocr_ai_invoice.ListView.Buttons.Invoice">
        <t t-call="web.ListView.Buttons"/>
        <t t-if="model.config.context.default_move_type === 'out_invoice'
                  or model.config.context.default_move_type === 'in_invoice'">
            <button type="button" class="btn btn-primary ms-2"
                    t-on-click="onClickOcrImport">
                Import via OCR
            </button>
        </t>
    </t>

    <!-- Purchase Orders -->
    <t t-name="ocr_ai_invoice.ListView.Buttons.Purchase">
        <t t-call="web.ListView.Buttons"/>
        <button type="button" class="btn btn-primary ms-2"
                t-on-click="onClickOcrImport">
            Import via OCR
        </button>
    </t>

    <!-- Sale Orders -->
    <t t-name="ocr_ai_invoice.ListView.Buttons.Sale">
        <t t-call="web.ListView.Buttons"/>
        <button type="button" class="btn btn-primary ms-2"
                t-on-click="onClickOcrImport">
            Import via OCR
        </button>
    </t>

    <!-- Stock Pickings (Receipts, Deliveries, Internal Transfers) -->
    <t t-name="ocr_ai_invoice.ListView.Buttons.Stock">
        <t t-call="web.ListView.Buttons"/>
        <button type="button" class="btn btn-primary ms-2"
                t-on-click="onClickOcrImport">
            Import via OCR
        </button>
    </t>

</templates>