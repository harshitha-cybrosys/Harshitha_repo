<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── List view ───────────────────────────────────────────────────── -->
        <record id="odoo_ocr_ai_config_tree_view" model="ir.ui.view">
            <field name="name">odoo.ocr.ai.config.list</field>
            <field name="model">odoo.ocr.ai.config</field>
            <field name="arch" type="xml">
                <list string="OCR Model Configurations">
                    <field name="model_id"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ── Form view ───────────────────────────────────────────────────── -->
        <record id="odoo_ocr_ai_config_form_view" model="ir.ui.view">
            <field name="name">odoo.ocr.ai.config.form</field>
            <field name="model">odoo.ocr.ai.config</field>
            <field name="arch" type="xml">
                <form string="OCR AI Configuration">
                    <sheet>
                        <group>
                            <group>
                                <field name="model_id"
                                       options="{'no_create': True}"
                                       help="Only models that have been flagged as OCR-enabled appear here."/>
                            </group>
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                        </group>

                        <group string="Options">
                            <group>
                                <field name="create_products_if_not_found"
                                       invisible="create_products_if_not_found_invisible"
                                       help="Auto-create products in Odoo when they are not found during line-item mapping."/>
                                <field name="create_products_if_not_found_invisible"
                                       invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Field Mapping" name="field_mapping">
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle"/>
                                    Map each AI-extracted field (Title) to the corresponding Odoo field.
                                    For relational fields (Many2one / One2many), you must also specify
                                    the <strong>Related Child Fields</strong> so the AI knows which
                                    sub-fields to return.
                                </div>
                                <field name="model_ids" editable="bottom">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="title" required="1"
                                               placeholder="e.g. Invoice Number"/>
                                        <field name="ocr_field_id"
                                               required="1"
                                               options="{'no_create': True, 'no_create_edit': True}"
                                               domain="[
                                                   ('model_id', '=', parent.model_id),
                                                   ('ttype', 'in', [
                                                       'char','date','datetime','integer',
                                                       'many2one','monetary','one2many',
                                                       'float','text'
                                                   ])
                                               ]"/>
                                        <!-- hidden helpers -->
                                        <field name="ttype" column_invisible="1"/>
                                        <field name="ocr_ir_field_ids_domain"
                                               column_invisible="1"/>
                                        <field name="create_products_if_not_found_invisible"
                                               column_invisible="1"/>
                                        <!-- child fields (only relevant for relational) -->
                                        <field name="ocr_ir_field_ids"
                                               widget="many2many_tags"
                                               domain="ocr_ir_field_ids_domain"
                                               options="{'no_create': True, 'no_create_edit': True}"/>
                                        <field name="create_if_not_found"
                                               invisible="ttype not in ['many2one'] or create_products_if_not_found_invisible"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── Search view ─────────────────────────────────────────────────── -->
        <record id="odoo_ocr_ai_config_search_view" model="ir.ui.view">
            <field name="name">odoo.ocr.ai.config.search</field>
            <field name="model">odoo.ocr.ai.config</field>
            <field name="arch" type="xml">
                <search>
                    <field name="model_id"/>
                    <filter string="Active"   name="active"   domain="[('active','=',True)]"/>
                    <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <!-- ── Actions ─────────────────────────────────────────────────────── -->
        <record id="odoo_ocr_ai_config_action" model="ir.actions.act_window">
            <field name="name">OCR AI Configurations</field>
            <field name="res_model">odoo.ocr.ai.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="ocr_ai_integration_action" model="ir.actions.act_window">
            <field name="name">Model Configuration</field>
            <field name="res_model">odoo.ocr.ai.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- ── Menus (under Settings) ──────────────────────────────────────── -->
        <menuitem id="ocr_ai_integration_main_menu"
                  name="OCR AI Integration"
                  parent="base.menu_administration"
                  action="odoo_ocr_ai_config_action"
                  sequence="20"/>

        <menuitem id="ocr_ai_configuration_menu"
                  name="Model Configuration"
                  action="ocr_ai_integration_action"
                  parent="ocr_ai_integration_main_menu"
                  sequence="2"/>

    </data>
</odoo>