<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ── Inject OCR button into Stock Pickings list view ──────────── -->
        <record id="view_stock_picking_tree_inherit_ocr" model="ir.ui.view">
            <field name="name">stock.picking.list.ocr.inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="js_class">ocr_button_stock</attribute>
                </xpath>
            </field>
        </record>

        <!-- ── Add OCR Details tab to Stock Picking form view ───────────── -->
        <record id="view_stock_picking_form_ocr_tab_inherit" model="ir.ui.view">
            <field name="name">stock.picking.form.ocr.tab.inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[1]" position="after">
                    <page string="OCR Details"
                          name="ocr_details"
                          invisible="not is_created_ocr">
                        <group>
                            <group string="Source">
                                <field name="is_created_ocr"
                                       string="Created via OCR"
                                       readonly="1"/>
                                <field name="ocr_attachment_id"
                                       string="Uploaded Document"
                                       readonly="1"/>
                            </group>
                        </group>
                        <group string="Raw OCR Response">
                            <field name="ocr_response_text"
                                   string="Extracted JSON"
                                   readonly="1"
                                   nolabel="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>