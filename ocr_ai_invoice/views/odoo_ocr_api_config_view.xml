<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ── List view ───────────────────────────────────────────────────── -->
        <record id="odoo_ocr_api_config_tree_view" model="ir.ui.view">
            <field name="name">odoo.ocr.api.config.list</field>
            <field name="model">odoo.ocr.api.config</field>
            <field name="arch" type="xml">
                <list editable="bottom" string="OCR API Configurations">
                    <field name="company_id"/>
                    <field name="server_url"/>
                    <field name="api_key" password="True"/>
                    <field name="date_format"/>
                    <button name="action_test_connection"
                            string="🌐 Manage Account"
                            type="object"
                            class="btn-primary"/>
                </list>
            </field>
        </record>

        <!-- ── Form view ───────────────────────────────────────────────────── -->
        <record id="odoo_ocr_api_config_form_view" model="ir.ui.view">
            <field name="name">odoo.ocr.api.config.form</field>
            <field name="model">odoo.ocr.api.config</field>
            <field name="arch" type="xml">
                <form string="OCR API Configuration">
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <i class="fa fa-info-circle"/>
                            Register at <a href="https://ai.fynix.app" target="_blank">https://ai.fynix.app</a>
                            to obtain your Authentication Token and purchase OCR credits.
                            The Server URL must be exactly: <strong>https://ai.fynix.app/tus_ocr_api</strong>
                        </div>
                        <group>
                            <group string="Connection">
                                <field name="company_id"/>
                                <field name="server_url"
                                       placeholder="https://ai.fynix.app/tus_ocr_api"/>
                                <field name="api_key"
                                       password="True"
                                       placeholder="Paste your Authentication Token here"/>
                            </group>
                            <group string="Parsing">
                                <field name="date_format"
                                       placeholder="%d-%m-%y"
                                       help="Python strptime format used to parse dates in OCR responses."/>
                            </group>
                        </group>
                        <div class="o_row mt8">
                            <button name="action_test_connection"
                                    string="🌐 Open fynix.ai Portal"
                                    type="object"
                                    class="btn btn-secondary"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── Action ──────────────────────────────────────────────────────── -->
        <record id="ocr_api_config_action" model="ir.actions.act_window">
            <field name="name">API Configuration</field>
            <field name="res_model">odoo.ocr.api.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- ── Menu ────────────────────────────────────────────────────────── -->
        <menuitem id="ocr_api_configuration_menu"
                  name="API Configuration"
                  action="ocr_api_config_action"
                  parent="ocr_ai_integration_main_menu"
                  sequence="1"/>

    </data>
</odoo>