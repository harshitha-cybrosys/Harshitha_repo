<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_pos_restrictions" model="ir.ui.view">
        <field name="name">res.users.form.inherit.pos.restrictions</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Point Of Sale" name="point_of_sale_restrictions">
                    <group string="POS Access Restrictions">
                        <field name="pos_allow_numpad"/>
                        <field name="pos_allow_payments"/>
                        <field name="pos_allow_discount"/>
                        <field name="pos_allow_qty"/>
                        <field name="pos_allow_price_edit"/>
                        <field name="pos_allow_remove_order_line"/>
                        <field name="pos_allow_customer_selection"/>
                        <field name="pos_allow_plus_minus"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>