<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form view for mailchimp.operations-->
    <record id="mailchimp_operations_view_form" model="ir.ui.view">
        <field name="name">mailchimp.operations.view.form</field>
        <field name="model">mailchimp.operations</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="mailchimp_account_ids"
                               widget="many2many_tags"/>
                    </group>
                    <group>
                        <group>
                            <field name="is_import_list"/>
                            <field name="is_import_template"/>
                            <field name="is_import_campaigns"/>
                        </group>
                        <group>
                            <field name="is_export_list"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Import" name="action_import"
                            type="object" default_focus="1"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Export" name="action_export"
                            type="object" default_focus="1"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
    <!--    Action window for mailchimp.operations-->
    <record id="action_mailchimp_operations" model="ir.actions.act_window">
        <field name="name">Mailchimp Operations</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mailchimp.operations</field>
        <field name="view_id" ref="mailchimp_operations_view_form"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
