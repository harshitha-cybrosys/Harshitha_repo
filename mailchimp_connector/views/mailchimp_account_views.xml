<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Mailchimp Account view-->
    <record id="action_mailchimp_account" model="ir.actions.act_window">
        <field name="name">Mailchimp Account</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mailchimp.account</field>
    </record>
<!--    Mailchimp account form view-->
    <record id="mailchimp_account_view_form" model="ir.ui.view">
        <field name="name">mailchimp.account.view.form</field>
        <field name="model">mailchimp.account</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="connect_mailchimp" string="Connect"
                            class="oe_highlight" type="object"/>
                    <field name="is_auth_success" invisible="1"/>
                </header>
                <sheet>
                    <group>
                                <field name="name"/>
                    </group>
                    <group string="Authentication">
                        <field name="api_key" password="1"/>
                        <field name="is_auth_success" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Settings">
                            <group name="Member Options">
                                <group>
                                    <field name="is_auto_sync"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
