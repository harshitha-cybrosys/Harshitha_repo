<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Inherit mailing contact for adding fields-->
    <record id="mailing_contact_view_form" model="ir.ui.view">
        <field name="name">
            mailing.contact.view.form.inherit.mailchimp.connector
        </field>
        <field name="model">mailing.contact</field>
        <field name="priority" eval="20"/>
        <field name="inherit_id" ref="mass_mailing.mailing_contact_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='country_id']" position="after">
                <field name="address"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="zip"/>
            </xpath>
        </field>
    </record>
</odoo>
