<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Inherit mailing for adding fields-->
    <record id="mailing_mailing_view_form_full_width" model="ir.ui.view">
        <field name="name">
            mailing.mailing.view.form.full.width.inherit.mailchimp.connector
        </field>
        <field name="model">mailing.mailing</field>
        <field name="priority" eval="20"/>
        <field name="inherit_id"
               ref="mass_mailing.view_mail_mass_mailing_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mailing_model_id']" position="after">
                <group>
                    <field name="template_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
