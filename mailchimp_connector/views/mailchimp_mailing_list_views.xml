<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        This record created for mail chimp contact view-->
    <record id="action_mailchimp_mailing_list" model="ir.actions.act_window">
        <field name="name">Mailchimp Mailing List</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="res_model">mailchimp.mailing.list</field>
    </record>
<!--    Mailchimp account list view-->
    <record id="mailchimp_mailing_list_view_form" model="ir.ui.view">
        <field name="name">mailchimp.mailing.list.view.form</field>
        <field name="model">mailchimp.mailing.list</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <div name="button_box" position="inside">
                    <button class="oe_stat_button"
                            type="object"
                            icon="fa-star"
                            name="action_import">
                        <field string="List Rating" name="list_rating_display"
                               widget="statinfo"/>
                    </button>
                    <button class="oe_stat_button"
                            type="object"
                            icon="fa-user"
                            name="action_import">
                        <field string="Contacts" name="member_count_display"
                               widget="statinfo"/>
                    </button>
                    <button class="oe_stat_button"
                            type="object"
                            icon="fa-bell"
                            name="action_import">
                        <field string="Unsubscribed Count"
                               name="unsubscribe_count_display"
                               widget="statinfo"/>
                    </button>
                    <button class="oe_stat_button"
                            type="object"
                            icon="fa-envelope-o"
                            name="action_import">
                        <field string="Campaign Count"
                               name="campaign_count_display"
                               widget="statinfo"/>
                    </button>
                    <button class="oe_stat_button"
                            type="object"
                            icon="fa-hand-pointer-o"
                            name="action_import">
                        <field string="Click Rate" name="click_rate_display"
                               widget="statinfo"/>
                    </button>
                </div>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="mailchimp_account_id"/>
                            <field name="state" readonly="1"/>
                            <field name="mailchimp_account_id"
                                   invisible="1"/>
                            <field name="create_date"
                                   string="Creation Date"/>
                            <field name="audience_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="permission_reminder"
                               string="Permission Reminder"/>
                        <field name="email_type_option"/>
                        <field name="list_rating"/>
                        <field name="member_count"/>
                        <field name="unsubscribe_count"/>
                        <field name="campaign_count"/>
                        <field name="click_rate"/>
                    </group>
                    <group string="Campaign Defaults">
                        <field name="from_name"/>
                        <field name="from_email"/>
                        <field name="subject"/>
                        <field name="lang_id"/>
                    </group>
                    <group string="Contacts">
                        <field name="company_id"/>
                        <field name="address"/>
                        <field name="city"/>
                        <field name="zip"/>
                        <field name="state_id"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<!--    This record for list view of mailchimp.mailing.list -->
    <record id="mailchimp_mailing_list_view_tree" model="ir.ui.view">
        <field name="name">mailchimp.mailing.list.view.tree</field>
        <field name="model">mailchimp.mailing.list</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="name"/>
                <field name="mailchimp_account_id"/>
                <field name="audience_id"/>
                <field name="create_date"
                       string="Creation Date"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'not_connected'"
                       decoration-success="state == 'connected'"/>
            </list>
        </field>
    </record>
</odoo>
