<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    This record of ir.actions.act_window mailchimp.template -->
    <record id="action_mailchimp_template" model="ir.actions.act_window">
        <field name="name">Mailchimp Templates</field>
        <field name="view_mode">list,form</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mailchimp.template</field>
    </record>
<!--    tree view for mailchimp.template-->
    <record id="mail_template_view_tree" model="ir.ui.view">
        <field name="name">mailchimp.template.view.tree</field>
        <field name="model">mailchimp.template</field>
        <field name="arch" type="xml">
            <list string="Mailchimp Templates">
                <field name="name"/>
                <field name="is_active"/>
                <field name="type"/>
                <field name="is_drag_drop"/>
                <field name="is_responsive"/>
                <field name="share_url"/>
            </list>
        </field>
    </record>
<!--    form view for mailchimp.template-->
    <record id="mailchimp_template_view_form" model="ir.ui.view">
        <field name="name">mailchimp.template.view.form</field>
        <field name="model">mailchimp.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="is_active"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="is_drag_drop"/>
                            <field name="share_url"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
<!--    menuitem form mailchimp template-->
    <menuitem id="mailchimp_templates_menu"
              name="Templates"
              action="action_mailchimp_template"
              parent="menu_mailchimp"
              sequence="1"/>
</odoo>
