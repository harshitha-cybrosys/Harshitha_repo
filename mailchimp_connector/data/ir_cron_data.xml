<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--        Automated action for syncing Lists, templates and campaigns-->
        <record id="auto_sync_lists_and_members" model="ir.cron">
            <field name="name">Sync mailchimp audiences, templates and
                campaigns
            </field>
            <field name="model_id" ref="model_mailchimp_operations"/>
            <field name="state">code</field>
            <field name="code">model.sync_mailchimp_list()</field>
            <field name='interval_number'>1</field>
            <field name='interval_type'>days</field>
        </record>
    </data>
</odoo>