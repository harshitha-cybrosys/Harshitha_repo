<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inject OCR button into Purchase Orders list view -->
        <record id="view_purchase_order_tree_inherit_ocr" model="ir.ui.view">
            <field name="name">purchase.order.list.ocr.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="js_class">ocr_button_purchase</attribute>
                </xpath>
            </field>
        </record>

        <!-- Add OCR Details tab to Purchase Order form -->
        <record id="view_purchase_order_form_ocr_tab_inherit" model="ir.ui.view">
            <field name="name">purchase.order.form.ocr.tab.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[1]" position="after">
                    <page string="OCR Details" name="ocr_details"
                          invisible="not is_created_ocr">
                        <group>
                            <group string="Source">
                                <field name="is_created_ocr" string="Created via OCR" readonly="1"/>
                                <field name="ocr_attachment_id" string="Uploaded Document" readonly="1"/>
                            </group>
                        </group>
                        <group string="Raw OCR Response">
                            <field name="ocr_response_text" readonly="1" nolabel="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>