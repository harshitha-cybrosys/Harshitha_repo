<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inject OCR button into Sale Orders list view -->
        <record id="view_sale_order_tree_inherit_ocr" model="ir.ui.view">
            <field name="name">sale.order.list.ocr.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="js_class">ocr_button_sale</attribute>
                </xpath>
            </field>
        </record>

        <!-- Add OCR Details tab to Sale Order form -->
        <record id="view_sale_order_form_ocr_tab_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.ocr.tab.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[1]" position="after">
                    <page string="OCR Details" name="ocr_details"
                          invisible="not is_created_ocr">
                        <group>
                            <group string="Source">
                                <field name="is_created_ocr" string="Created via OCR" readonly="1"/>
                                <field name="ocr_attachment_id" string="Uploaded Document" readonly="1"/>
                            </group>
                        </group>
                        <group string="Raw OCR Response">
                            <field name="ocr_response_text" readonly="1" nolabel="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>