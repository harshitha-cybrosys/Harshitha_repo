<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Wizard form view ─────────────────────────────────────────────── -->
        <record id="import_via_ocr_wizard_form" model="ir.ui.view">
            <field name="name">import.via.ocr.wizard.form</field>
            <field name="model">import.via.ocr</field>
            <field name="arch" type="xml">
                <form string="Import Document via OCR AI">
                    <sheet>
                        <group>
                            <field filename="file_upload_name"
                                   name="file_upload"
                                   string="Upload Document (PDF / PNG / JPG)"
                                   widget="binary"/>
                            <field name="file_upload_name" invisible="1"/>
                            <field name="ocr_attachment_id" invisible="1"/>
                            <field name="status" invisible="1"/>
                            <field name="ocr_response_received" invisible="1"/>
                            <field name="mime_type" invisible="1"/>
                        </group>

                        <div class="o_row mt8">
                            <button name="action_send_to_ocr"
                                    string="Send to OCR"
                                    type="object"
                                    class="btn btn-primary"
                                    data-hotkey="q"
                                    invisible="not file_upload"/>
                            <button name="action_create_record"
                                    string="Create Record"
                                    type="object"
                                    class="btn btn-success ms-2"
                                    data-hotkey="w"
                                    invisible="not ocr_response_received or not file_upload or not status"/>
                        </div>

                        <div class="alert alert-info mt8" role="alert">
                            <i class="fa fa-info-circle"/> Supported formats:
                            <strong>PDF, PNG, JPG, JPEG</strong> — max <strong>2 MB</strong>.
                        </div>

                        <notebook invisible="not ocr_response_received">

                            <page string="Response Preview" invisible="not file_upload">
                                <field name="response_text"
                                       string="Extracted Data (JSON)"
                                       readonly="1"/>
                            </page>

                            <page string="File Preview"
                                  invisible="not file_upload or not status">
                                <field name="file_upload"
                                       filename="file_upload_name"
                                       widget="pdf_viewer"
                                       readonly="1"
                                       invisible="mime_type != 'application/pdf'"/>
                                <field name="file_upload"
                                       filename="file_upload_name"
                                       widget="image"
                                       options='{"zoom": true}'
                                       readonly="1"
                                       invisible="mime_type not in ['image/jpeg', 'image/png']"/>
                            </page>

                            <page string="Token Usage"
                                  invisible="not file_upload or not status">
                                <group>
                                    <group string="This Request">
                                        <field name="used_token"
                                               string="Tokens Consumed"
                                               readonly="1"/>
                                    </group>
                                    <group string="Account Summary">
                                        <field name="total_purchase_token"
                                               string="Total Purchased"
                                               readonly="1"/>
                                        <field name="total_used_token"
                                               string="Total Used"
                                               readonly="1"/>
                                        <field name="total_available_token"
                                               string="Available Balance"
                                               readonly="1"/>
                                    </group>
                                </group>
                            </page>

                        </notebook>
                    </sheet>

                    <footer>
                        <button string="Close"
                                class="btn btn-secondary"
                                data-hotkey="x"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ── Action used by form view stat buttons ─────────────────────────── -->
        <record id="import_via_ocr_action" model="ir.actions.act_window">
            <field name="name">Import via OCR</field>
            <field name="res_model">import.via.ocr</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{
                'default_move_type': context.get('default_move_type'),
                'active_model': active_model,
            }</field>
        </record>

    </data>
</odoo>